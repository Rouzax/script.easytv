<?xml version="1.0" encoding="UTF-8"?>
<!--
    EasyTV Next Episode Dialog
    Resolution: 1080i (1920x1080)

    Control IDs:
        1  - Heading label (static, addon/clone name)
        2  - Message label (primary)
        3  - Timer label (auto-close countdown, below buttons)
        4  - Subtitle label (secondary — episode title, smaller + dimmer)
        10 - "Yes" button (left)
        11 - "No" button (right)
        20 - Show poster image
-->
<window>
    <zorder>100000</zorder>
    <defaultcontrol always="true">10</defaultcontrol>

    <controls>
        <!-- Dim overlay -->
        <control type="image">
            <left>0</left>
            <top>0</top>
            <width>1920</width>
            <height>1080</height>
            <texture colordiffuse="BB000000">common/white.png</texture>
            <animation type="WindowOpen" reversible="false">
                <effect type="fade" start="0" end="100" time="300" />
            </animation>
            <animation type="WindowClose" reversible="false">
                <effect type="fade" start="100" end="0" time="300" />
            </animation>
        </control>

        <!-- Dialog Container: 800x460 centered -->
        <control type="group">
            <left>560</left>
            <top>310</top>
            <width>800</width>
            <height>460</height>
            <include>EasyTV_BounceIn</include>
            <include>EasyTV_BounceClose</include>

            <!-- Accent border frame -->
            <control type="image">
                <left>-2</left>
                <top>-2</top>
                <width>804</width>
                <height>464</height>
                <texture border="12" colordiffuse="$INFO[Window.Property(EasyTV.Accent)]">common/white_rounded.png</texture>
            </control>

            <!-- Rounded dark panel background -->
            <control type="image">
                <left>0</left>
                <top>0</top>
                <width>800</width>
                <height>460</height>
                <texture border="12">common/menu.png</texture>
                <colordiffuse>ffffffff</colordiffuse>
            </control>

            <!-- Heading Label (ID 1) — centered across full dialog -->
            <control type="label" id="1">
                <left>30</left>
                <top>25</top>
                <width>740</width>
                <height>40</height>
                <align>center</align>
                <textcolor>$INFO[Window.Property(EasyTV.Accent)]</textcolor>
                <font>font14_title</font>
                <label>-</label>
            </control>

            <!-- Accent line separator below heading (inlined — includes don't render in WindowXMLDialog) -->
            <control type="image">
                <left>30</left>
                <top>72</top>
                <width>740</width>
                <height>2</height>
                <texture colordiffuse="$INFO[Window.Property(EasyTV.AccentGlow)]">common/line_fade.png</texture>
            </control>

            <!-- Show Poster (ID 20): 150x225 -->
            <control type="image" id="20">
                <left>50</left>
                <top>85</top>
                <width>150</width>
                <height>225</height>
                <aspectratio>keep</aspectratio>
                <texture>-</texture>
            </control>

            <!-- Message Label (ID 2) — show title, right of poster -->
            <control type="label" id="2">
                <left>230</left>
                <top>145</top>
                <width>540</width>
                <height>60</height>
                <align>left</align>
                <aligny>center</aligny>
                <textcolor>ffFFFFFF</textcolor>
                <font>font14_title</font>
                <wrapmultiline>true</wrapmultiline>
                <label>-</label>
            </control>

            <!-- Subtitle Label (ID 4) — episode info, smaller + dimmer -->
            <control type="label" id="4">
                <left>230</left>
                <top>210</top>
                <width>540</width>
                <height>25</height>
                <align>left</align>
                <font>font10</font>
                <textcolor>FFAAAAAA</textcolor>
                <label>-</label>
            </control>

            <!-- Button Row — below poster area -->
            <control type="group">
                <left>150</left>
                <top>330</top>
                <width>500</width>
                <height>50</height>

                <!-- Yes Button (ID 10) -->
                <control type="button" id="10">
                    <left>0</left>
                    <top>0</top>
                    <width>235</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>11</onright>
                    <onleft>11</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>

                <!-- No Button (ID 11) -->
                <control type="button" id="11">
                    <left>265</left>
                    <top>0</top>
                    <width>235</width>
                    <height>50</height>
                    <align>center</align>
                    <aligny>center</aligny>
                    <font>font12</font>
                    <textoffsetx>10</textoffsetx>
                    <textcolor>FFFFFFFF</textcolor>
                    <focusedcolor>$INFO[Window.Property(EasyTV.ButtonTextFocused)]</focusedcolor>
                    <onright>10</onright>
                    <onleft>10</onleft>
                    <texturefocus border="12" colordiffuse="$INFO[Window.Property(EasyTV.ButtonFocus)]">common/white_rounded.png</texturefocus>
                    <texturenofocus border="12" colordiffuse="1fFFFFFF">common/white_rounded.png</texturenofocus>
                </control>
            </control>

            <!-- Timer Label (ID 3) — auto-close countdown -->
            <control type="label" id="3">
                <left>150</left>
                <top>395</top>
                <width>500</width>
                <height>30</height>
                <align>center</align>
                <font>font10</font>
                <textcolor>FFAAAAAA</textcolor>
                <label>-</label>
            </control>
        </control>
    </controls>
</window>
